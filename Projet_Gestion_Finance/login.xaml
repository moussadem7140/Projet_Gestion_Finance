<Window x:Class="Projet_Gestion_Finance.Views.Login"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Projet_Gestion_Finance.Views"
        mc:Ignorable="d"
        Title="login" Height="400" Width="580" Background="#E52C3E50">
    <Grid >
        <Border Width="420" Height="370"
               CornerRadius="12"
                BorderBrush="#AAFFFFFF" BorderThickness="1"
                HorizontalAlignment="Center" VerticalAlignment="Center"
                Padding="13">
            <StackPanel Orientation="Vertical" Width="410" Height="316" Background="#8EF5F5F5">
                <TextBlock Margin="0,15,0,0" FontFamily="Arial Rounded MT Bold" FontSize="14" HorizontalAlignment="Center">GestuPro</TextBlock>
                <TextBlock Margin="0,18,0,0" FontSize="14" HorizontalAlignment="Center">Connecter vous a votre compte</TextBlock>
                <StackPanel Orientation="Vertical" Margin="6,24,6,0" Width="340" Height="70">
                    <Label Margin="0,0,0,3" FontWeight="Bold">Identifiant</Label>
                    <TextBox x:Name="txtIdConn" Width="250" HorizontalAlignment="Left" Height="21" Panel.ZIndex="-1" Margin="4,-3,0,0">
                    </TextBox>
                    <TextBlock x:Name="txtMsgErrid" Foreground="#FFC90E0E" Height="20"></TextBlock>
                </StackPanel>
                <StackPanel Orientation="Vertical" Margin="6,5,6,7" Width="340" Height="70">
                    <Label Margin="0,0,0,3" FontWeight="Bold">Mot de passe</Label>
                    <PasswordBox x:Name="txtMdpConn" Width="250" HorizontalAlignment="Left" Height="21" Panel.ZIndex="-1" Margin="4,-3,0,0">
                    </PasswordBox>
                    <TextBlock x:Name="txtMsgErrMdp" Foreground="#FFC90E0E" Height="18"></TextBlock>
                </StackPanel>
                <Button Width="90" Content="Se Connecter" Margin="0,5,0,0" Background="#FF232732" Foreground="White" Click="Button_Click"/>
                <StackPanel Orientation="Horizontal" Margin="0,15,0,0">
                    <TextBlock Margin="28,0,0,0">Vous n'avez pas encore de compte?</TextBlock>
                    <TextBlock Margin="10,0,0,0" Foreground="#FF0A16B7" TextDecorations="Underline" FontFamily="Book Antiqua" FontSize="14" MouseRightButtonDown="TextBlock_MouseRightButtonDown">S'inscrire</TextBlock>
                </StackPanel>
            </StackPanel>
        </Border>
    </Grid>
</Window>
