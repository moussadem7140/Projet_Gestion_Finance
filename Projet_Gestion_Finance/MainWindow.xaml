<Window x:Class="Projet_Gestion_Finance.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Projet_Gestion_Finance"
        mc:Ignorable="d"
        Title="Gestion de Finance" Height="360" Width="820" Loaded="Window_Loaded">
    <StackPanel Margin="10">
        <TabControl>
            <TabItem Header="Liste des dépenses" FontWeight="Bold">
                <StackPanel>
                    <StackPanel Margin="0,0,75,0" x:Name="spAjouterProduit" Orientation="Horizontal" >
                        <TextBox x:Name="txtRechercher" Width="250" Height="25" Margin="10"  />
                        <ComboBox x:Name="cboCategories" Width="150" Margin="10"/>
                        <Button x:Name="btnRechercherProduit" Margin="10" BorderThickness="0" Background="White">
                            <Image Source="/Ressource/search.png" Width="25" Margin="5" />
                        </Button>
                    </StackPanel>
                    <StackPanel  Orientation="Horizontal">
                        <TextBlock  Text="NOM" FontWeight="Bold"  HorizontalAlignment="Left" Margin="0,0,265,0" />
                        <TextBlock  Text="Coût" FontWeight="Bold"  HorizontalAlignment="Left" Margin="0,0,150,0" />
                        <TextBlock  Text="Date" FontWeight="Bold"  HorizontalAlignment="Left" Margin="0,0,130,0"/>
                        <TextBlock  Text="Categorie" FontWeight="Bold"  HorizontalAlignment="Left" Margin="0,0,50,0" />
                    </StackPanel>
                    <StackPanel >
                        <ListBox x:Name="lstDepenses"   Width="740" Height="200" VerticalAlignment="top" Margin="0,0,10,0" HorizontalAlignment="Left" FontFamily="Courier New"></ListBox>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,10">
                        <Button x:Name="btnAjouterDepense"  Content="Ajouter"  Width="100" Height="25" />
                        <Button x:Name="btnModifierDepense"  Content="Modifier"  Width="100" Height="25" Margin="10,0,0,0" />
                        <Button x:Name="btnSupprimerDepense"   Content="Supprimer"  Width="100" Height="25" Margin="10,0,0,0" />
                    </StackPanel>
                </StackPanel>
            </TabItem>
            <TabItem Header="Gestion des Categories" FontWeight="Bold">
                <StackPanel>
                    <StackPanel  Orientation="Horizontal">
                        <TextBlock  Text="NOM" FontWeight="Bold"  HorizontalAlignment="Left" Margin="0,0,265,0" />
                        <TextBlock  Text="Limite_Depenses" FontWeight="Bold"  HorizontalAlignment="Left" Margin="0,0,50,0" />
                    </StackPanel>
                    <StackPanel >
                        <ListBox x:Name="lstCategorie"   Width="740" Height="200" VerticalAlignment="top" Margin="0,0,10,0" HorizontalAlignment="Left" FontFamily="Courier New"></ListBox>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,10">
                        <Button x:Name="btnCreerCategorie"  Content="Creer"  Width="100" Height="25" Click="btnCreerCategorie_Click"/>
                        <Button x:Name="btnModifierCategorie"  Content="Modifier"  Width="100" Height="25" Margin="10,0,0,0" />
                        <Button x:Name="btnSupprimerCategorie"   Content="Supprimer"  Width="100" Height="25" Margin="10,0,0,0"/>
                    </StackPanel>
                </StackPanel>
            </TabItem>
        </TabControl>
    </StackPanel>
</Window>
