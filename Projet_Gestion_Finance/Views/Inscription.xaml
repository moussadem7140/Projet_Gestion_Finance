<Window x:Class="Projet_Gestion_Finance.Views.Inscription"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Projet_Gestion_Finance.Views"
        mc:Ignorable="d"
        Title="Inscription" Height="540" Width="470"  WindowStartupLocation="CenterScreen" Loaded="Window_Loaded" Background="#E52C3E50">
    <Grid >
        <Border BorderThickness="2" CornerRadius="3,3,3,3">
            <StackPanel Orientation="Vertical" Width="470" Margin="0,22,-4,-27">
                <TextBlock x:Name="txtblkTitre" HorizontalAlignment="Center"  Margin="0,11,0,0" FontWeight="Bold" Foreground="White"  FontFamily="Arial Rounded MT Bold" FontSize="16">Inscription</TextBlock>
                <TextBlock FontSize="14" FontFamily="Cambria" Foreground="White"  HorizontalAlignment="Center" Margin="0,10,0,0">Votre outil de gestion de finances personelles</TextBlock>
                <StackPanel Orientation="Horizontal" Margin="13,19,16,0">
                    <Label Width="90" Foreground="White" >Nom</Label>
                    <StackPanel Orientation="Vertical">
                        <TextBox x:Name="txtNomIns" Width="240" Height="23" Background="White"></TextBox>
                        <TextBlock x:Name="txtNomInsError" Foreground="Red" FontSize="10" FontWeight="Bold" Margin="0,0,0,0"></TextBlock>
                    </StackPanel>
                </StackPanel>
                <StackPanel Orientation="Horizontal" Margin="13,15,16,0">
                    <Label Width="90" Foreground="White" >Prénom</Label>
                    <StackPanel Orientation="Vertical">
                        <TextBox x:Name="txtPrenomIns" Width="240" Height="23" Background="White"></TextBox>
                        <TextBlock x:Name="txtPrenomInsError" Foreground="Red" FontSize="10" FontWeight="Bold" Margin="0,0,0,0"></TextBlock>
                    </StackPanel>
                </StackPanel>
                <StackPanel Orientation="Horizontal" Margin="13,15,16,0">
                    <Label Width="90" Foreground="White" >Mail</Label>
                    <StackPanel Orientation="Vertical">
                        <TextBox x:Name="txtMailIns" Width="240" Height="23" Background="White"></TextBox>
                        <TextBlock x:Name="txtMailInsError" Foreground="Red" FontSize="10" FontWeight="Bold" Margin="0,0,0,0"></TextBlock>
                    </StackPanel>
                </StackPanel>
                <StackPanel Orientation="Horizontal" Margin="13,15,16,0">
                    <Label Width="90" Foreground="White" >Revenus</Label>
                    <StackPanel Orientation="Vertical">
                        <TextBox x:Name="txtRevenuIns" Width="240" Height="23" Background="White"></TextBox>
                        <TextBlock x:Name="txtRevenuInsError" Foreground="Red" FontSize="10" FontWeight="Bold" Margin="0,0,0,0"></TextBlock>
                    </StackPanel>
                </StackPanel>
                <StackPanel Orientation="Horizontal" Margin="13,15,16,0">
                    <Label Width="90" Foreground="White" >Mot de passe</Label>
                    <StackPanel Orientation="Vertical">
                        <PasswordBox x:Name="txtMdpIns" Width="240" Height="23" Background="White"></PasswordBox>
                        <TextBlock x:Name="txtMdpInsError" Foreground="Red" FontSize="10" FontWeight="Bold" Margin="0,0,0,0"></TextBlock>
                    </StackPanel>
                </StackPanel>
                <StackPanel Orientation="Horizontal" Margin="13,15,16,0">
                    <Label Foreground="White"  Width="90">Confirmer mot de passe</Label>
                    <StackPanel Orientation="Vertical">
                        <PasswordBox x:Name="txtMdpConfIns" Width="240" Height="23" Background="White"></PasswordBox>
                        <TextBlock x:Name="txtMdpConfInsError" Foreground="Red" FontSize="10" FontWeight="Bold" Margin="0,0,0,0"></TextBlock>
                    </StackPanel>
                </StackPanel>
                <Button x:Name="btnInscription" Content="S'inscrire" Width="100" Height="30" Background="Green" Foreground="White" FontWeight="Bold" FontSize="12" Click="btnInscription_Click"/>
                <StackPanel Orientation="Horizontal" Margin="0,10,0,0">
                    <TextBlock x:Name="s" Margin="28,0,0,0" Foreground="White" >Vous avez déjà un compte?</TextBlock>
                    <TextBlock x:Name="p" Margin="10,0,0,0" Foreground="#FF0A16B7" TextDecorations="Underline" FontFamily="Book Antiqua" FontSize="14" MouseRightButtonDown="TextBlock_MouseRightButtonDown">Se Connecter</TextBlock>
                </StackPanel>
            </StackPanel>
        </Border>
    </Grid>
</Window>
