<Window x:Class="Projet_Gestion_Finance.Views.Accueil"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Projet_Gestion_Finance.Views" 
        xmlns:lvc="clr-namespace:LiveCharts.Wpf;assembly=LiveCharts.Wpf"
        mc:Ignorable="d"
        Title="Accueil" Height="800" Width="880" WindowStartupLocation="CenterScreen" WindowState="Maximized" Loaded="Window_Loaded">

    <Grid>
        <!-- Image de fond -->
        <Grid.Background>
            <ImageBrush ImageSource="/Ressource/imagedefond.jpg" Stretch="UniformToFill"/>
        </Grid.Background>

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="300"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Panneau gauche -->
        <StackPanel Orientation="Vertical" Grid.Column="0" Background="#992C3E50" Margin="-10,0,10,0">
            <Grid HorizontalAlignment="Center" VerticalAlignment="Top" Margin="0,38,0,0">
                <Ellipse Fill="AliceBlue" Width="125" Height="119"/>
                <TextBlock x:Name="txtInitiales" Text=" OT" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="#E52C3E50" FontWeight="Bold" Width="90" Height="79" FontSize="48"/>
            </Grid>
            <TextBlock FontSize="19" Margin="0,15,0,0" FontWeight="Bold" HorizontalAlignment="Center" Foreground="AliceBlue" Name="txtNom"/>
            <StackPanel Orientation="Horizontal" Margin="0,15,0,0">
                <Image Source="/Ressource/Icons/edit.png" Width="50" Height="50" Margin="40,0,0,0" MouseDown="Image_MouseDown_1"/>
                <Image Source="/Ressource/Icons/logout.png" Width="50" Height="50" Margin="35,0,0,0" MouseDown="Image_MouseDown"/>
            </StackPanel>
        </StackPanel>

        <!-- Contenu principal -->
        <Border Opacity="0.90" Grid.Column="1">
            <StackPanel Orientation="Vertical">
                <TextBlock FontSize="40" Margin="20,18,0,0" FontWeight="Bold" HorizontalAlignment="Left"  FontFamily="Segoe UI">Gestion des finances</TextBlock>

                <StackPanel Orientation="Vertical">
                    <!-- Cartes Revenus / Dépenses / Projets -->
                    <StackPanel Orientation="Vertical" Width="510" HorizontalAlignment="Center" Margin="0,18,0,0">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <!-- Carte Revenus -->
                            <StackPanel Orientation="Horizontal" Width="145" Height="70" Background="#992C3E50" MouseDown="StackPanel_MouseDown">
                                <Image Source="/Ressource/Icons/bonus.png" Width="45" Height="45" Margin="9,0,0,0"/>
                                <StackPanel Orientation="Vertical" Margin="6" Width="80">
                                    <TextBlock FontSize="16" HorizontalAlignment="Center"  Margin="0,6,9,5" FontWeight="Bold" Foreground="White">Revenus</TextBlock>
                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                        <TextBlock Text="$ " FontSize="18"/>
                                        <TextBlock FontSize="18" Text="{Binding Revenue}"/>
                                    </StackPanel>
                                </StackPanel>
                            </StackPanel>

                            <!-- Carte Dépenses -->
                            <StackPanel Grid.Column="1" Orientation="Horizontal" Width="147" Height="70" Background="#992C3E50" MouseDown="StackPanel_MouseDown_1">
                                <Image Source="/Ressource/Icons/money.png" Width="50" Height="50" Margin="8,0,0,0"/>
                                <StackPanel Orientation="Vertical" Margin="6" Width="85">
                                    <TextBlock FontSize="15" HorizontalAlignment="Center" Foreground="White" Margin="0,6,14,5" FontWeight="Bold">Dépenses</TextBlock>
                                    <TextBlock HorizontalAlignment="Center" FontSize="18"/>
                                </StackPanel>
                            </StackPanel>

                            <!-- Carte Projets -->
                            <StackPanel Grid.Column="2" Orientation="Horizontal" Width="150" Height="70" Background="#992C3E50" MouseDown="StackPanel_MouseDown_2">
                                <Image Source="/Ressource/Icons/list.png" Width="40" Height="45" Margin="8,0,0,0"/>
                                <StackPanel Orientation="Vertical" Margin="6" Width="91">
                                    <TextBlock FontSize="15" HorizontalAlignment="Center" Foreground="White" Margin="0,6,3,5" FontWeight="Bold">Projets</TextBlock>
                                    <TextBlock HorizontalAlignment="Center" FontSize="18"/>
                                </StackPanel>
                            </StackPanel>
                        </Grid>
                    </StackPanel>

                    <!-- Statistiques -->
                    <StackPanel Orientation="Vertical" Margin="0,30,0,0">
                        <Label Margin="12,23,0,10" Width="228" HorizontalAlignment="Left" Height="30" FontSize="16" FontWeight="Bold">Vos Statistiques</Label>

                        <StackPanel Orientation="Horizontal">
                            <Label Width="120">Début de la période</Label>
                            <DatePicker Width="105" x:Name="dtpDebutPeriode" Height="26"/>
                            <Label Width="110" Margin="30,0,0,0">Fin de la période</Label>
                            <DatePicker Width="105" x:Name="dtpFinPeriode" Height="26"/>
                            <Button x:Name="btnValider" Content="Valider" Width="75" Height="26" Margin="30,0,0,0" Background="#992C3E50" Foreground="White" FontWeight="Bold" Cursor="Hand" Click="btnValider_Click"/>
                        </StackPanel>

                        <!-- Graphiques -->
                        <StackPanel Orientation="Horizontal">
                            <StackPanel Orientation="Vertical" ScrollViewer.CanContentScroll="True">
                                <lvc:CartesianChart x:Name="graphique" Height="255" Width="462" HorizontalAlignment="Left" Margin="39,30,0,34">
                                    <lvc:CartesianChart.AxisX>
                                        <lvc:Axis Title="Catégories" x:Name="Labels"/>
                                    </lvc:CartesianChart.AxisX>
                                    <lvc:CartesianChart.AxisY>
                                        <lvc:Axis Title="Montant ($)" />
                                    </lvc:CartesianChart.AxisY>
                                </lvc:CartesianChart>
                                <lvc:PieChart x:Name="depensesRevenues"
                                              LegendLocation="Right" Height="334" Width="395"/>
                            </StackPanel>
                        </StackPanel>
                    </StackPanel>
                </StackPanel>
            </StackPanel>
        </Border>
    </Grid>
</Window>