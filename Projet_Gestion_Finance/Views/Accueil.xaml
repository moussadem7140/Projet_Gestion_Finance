<Window x:Class="Projet_Gestion_Finance.Views.Accueil"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Projet_Gestion_Finance.Views"
        mc:Ignorable="d"
        Title="Accueil" Height="550" Width="800" WindowStartupLocation="CenterScreen" WindowState="Maximized" Loaded="Window_Loaded">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="300"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>
        <!--<Grid.RowDefinitions>
            <RowDefinition Height="90"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>-->
        <StackPanel Orientation="Vertical" Grid.Column="0" Background="#E52C3E50" Margin="-10,0,10,0">
            <Grid HorizontalAlignment="Center" VerticalAlignment="Top" Margin="0,38,0,0">
                <Ellipse Fill="#FFFFFF" Width="125" Height="119"/>
                <TextBlock x:Name="txtInitiales" Text=" OT" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="#E52C3E50" FontWeight="Bold" Width="90" Height="79" FontSize="48"/>
            </Grid>
            <StackPanel Orientation="Horizontal" Margin="0,15,0,0">
                <TextBlock FontSize="19" Margin="0,10,0,0"  FontWeight="Bold" HorizontalAlignment="Left" Foreground="#FFFFFF" Name="txtNom"></TextBlock>
            </StackPanel>
            <StackPanel Orientation="Horizontal" Margin="0,15,0,0">
                <Image Source="/Ressource/Icons/edit.png" Width="50" Height="50" Margin="40,0,0,0" MouseDown="Image_MouseDown_1"></Image>
                <Image Source="/Ressource/Icons/logout.png" Width="50" Height="50" Margin="35,0,0,0" MouseDown="Image_MouseDown"></Image>
            </StackPanel>
        </StackPanel>
        <Border Background="#FFFFFF" Grid.Column="1">
            <StackPanel Orientation="Vertical">
                <TextBlock FontSize="40" Margin="20,18,0,0"  FontWeight="Bold" HorizontalAlignment="Left" Foreground="#E52C3E50">Gestion des finances</TextBlock>
                <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto">
                    <StackPanel Orientation="Vertical">
                        <StackPanel Orientation="Vertical" Width="510" HorizontalAlignment="Center" Margin="0,18,0,0">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Orientation="Horizontal" Width="145" Height="70" Background="#F2F2EF" MouseDown="StackPanel_MouseDown">
                                    <Image Source="/Ressource/Icons/bonus.png" Width="45" Height="45" Margin="9,0,0,0"></Image>
                                    <StackPanel Orientation="Vertical" Margin="6" Width="80">
                                        <TextBlock FontSize="16" HorizontalAlignment="Center" Foreground="#FF2C3E50" Margin="0,6,9,5" FontFamily="Lucida Sans" FontWeight="Bold">Revenus</TextBlock>
                                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                            <TextBlock Text="$ "  FontSize="18"></TextBlock>
                                            <TextBlock FontSize="18" Text="{Binding Revenue}"></TextBlock>
                                        </StackPanel>
                                    </StackPanel>
                                </StackPanel>
                                <StackPanel Grid.Column="1" Orientation="Horizontal" Width="147" Height="70" Background="#F2F2EF" MouseDown="StackPanel_MouseDown_1">
                                    <Image Source="/Ressource/Icons/money.png" Width="50" Height="50" Margin="8,0,0,0"></Image>
                                    <StackPanel Orientation="Vertical" Margin="6" Width="85">
                                        <TextBlock FontSize="15" HorizontalAlignment="Center" Foreground="#FF2C3E50" Margin="0,6,14,5"  FontWeight="Bold">Dépenses</TextBlock>
                                        <TextBlock HorizontalAlignment="Center" FontSize="18"></TextBlock>
                                    </StackPanel>
                                </StackPanel>
                                <StackPanel Grid.Column="2" Orientation="Horizontal" Width="150" Height="70" Background="#F2F2EF" MouseDown="StackPanel_MouseDown_2">
                                    <Image Source="/Ressource/Icons/list.png" Width="40" Height="45" Margin="8,0,0,0"></Image>
                                    <StackPanel Orientation="Vertical" Margin="6" Width="91">
                                        <TextBlock FontSize="15" HorizontalAlignment="Center" Foreground="#FF2C3E50" Margin="0,6,3,5" FontWeight="Bold">Projets</TextBlock>
                                        <TextBlock HorizontalAlignment="Center" FontSize="18"></TextBlock>
                                    </StackPanel>
                                </StackPanel>
                            </Grid>
                        </StackPanel>
                        <StackPanel Orientation="Vertical">

                        </StackPanel>
                    </StackPanel>
                </ScrollViewer>
            </StackPanel>
        </Border>
    </Grid>

</Window>
