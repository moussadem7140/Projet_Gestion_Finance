<Window x:Class="Projet_Gestion_Finance.Views.Login"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Projet_Gestion_Finance.Views"
        mc:Ignorable="d"
        Title="Connexion"
        Height="400" Width="580" WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize">

    <Grid>
        <!-- Image de fond harmonisée -->
        <Grid.Background >
            <ImageBrush ImageSource="/Ressource/imagedefond.jpg" Stretch="UniformToFill"/>
        </Grid.Background>
       
        <!-- Boîte centrale -->
        <Border Width="420" Height="330"
                Background="#992C3E50" CornerRadius="12"
                BorderBrush="#AAFFFFFF" BorderThickness="1"
                HorizontalAlignment="Center" VerticalAlignment="Center"
                Padding="20">
            <StackPanel Orientation="Vertical">
                <!-- Titre -->
                <TextBlock Text="Nom de l'app"
                           FontFamily="Segoe UI Semibold"
                           FontSize="20"
                           Foreground="White"
                           HorizontalAlignment="Center"
                           Margin="0,10,0,5"/>

                <TextBlock Text="Connectez-vous à votre compte"
                           FontSize="14"
                           Foreground="White"
                           HorizontalAlignment="Center"
                           Margin="0,0,0,20"/>

                <!-- Identifiant -->
                <TextBlock  Foreground="White" Text="Identifiant" FontWeight="Bold" Margin="0,5,0,2"/>
                <TextBox x:Name="txtIdConn" Height="28" Background="WhiteSmoke" BorderBrush="LightGray"/>
                <TextBlock x:Name="txtMsgErrid" Foreground="Red" FontSize="12" Margin="0,2,0,8"/>

                <!-- Mot de passe -->
                <TextBlock Text="Mot de passe"  Foreground="White" FontWeight="Bold" Margin="0,5,0,2"/>
                <PasswordBox x:Name="txtMdpConn" Height="28" Background="WhiteSmoke" BorderBrush="LightGray"/>
                <TextBlock x:Name="txtMsgErrMdp" Foreground="Red" FontSize="12" Margin="0,2,0,10"/>

                <!-- Bouton de connexion -->
                <Button Content="Se connecter"
                        Width="120" Height="35"
                        Background="LightSteelBlue"
                        Foreground="White"
                        FontWeight="Bold"
                        HorizontalAlignment="Center"
                        Cursor="Hand"
                        Click="Button_Click"/>

                <!-- Lien inscription -->
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,15,0,0">
                    <TextBlock Text="Pas encore de compte ?" FontSize="12"/>
                    <TextBlock Text=" S'inscrire"
                               Foreground="#0A16B7"
                               FontSize="12"
                               TextDecorations="Underline"
                               Cursor="Hand"
                               MouseLeftButtonDown="TextBlock_MouseRightButtonDown"/>
                </StackPanel>
            </StackPanel>
        </Border>
    </Grid>
</Window>