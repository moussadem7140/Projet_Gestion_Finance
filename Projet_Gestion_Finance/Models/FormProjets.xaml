<Window x:Class="Projet_Gestion_Finance.Models.FormProjets"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Projet_Gestion_Finance.Models"
        mc:Ignorable="d"
        Title="FormProjets" Height="450" Width="800" Loaded="Window_Loaded">
    <Grid>
        <StackPanel>
            <StackPanel.Background>
                <ImageBrush ImageSource="/Ressource/imagedefond.jpg" Stretch="UniformToFill"></ImageBrush>
            </StackPanel.Background>
            <StackPanel Margin="0,0,100,0" Orientation="Horizontal" HorizontalAlignment="Right" Width="485">
                <TextBlock Text="Etat prévu des projets pour le " Width="175" Height="25" Margin="0,10"  Foreground="Black" FontWeight="Bold" />
                <DatePicker x:Name="dtpDate" Width="100" Height="25" Margin="0,10"/>
                <Button x:Name="btnRefresh" Margin="10" BorderThickness="0" Height="26" Width="79">
                    <Image Source="/Ressource/refresh.png" Width="56" Height="25" RenderTransformOrigin="0.777,0.5" MouseLeftButtonDown="btnRefresh_Click"/>
                </Button>
            </StackPanel>
            <GroupBox Header="Liste des projets">
                <StackPanel Height="867" Margin="0,0,-70,0">
                    <StackPanel >
                        <ListView Background="AliceBlue" x:Name="lstProjets" Width="740" Height="200">
                            <ListView.View>
                                <GridView>
                                    <GridViewColumn  Header="NOM" DisplayMemberBinding="{Binding Nom}" Width="150"/>
                                    <GridViewColumn Header="Avancement"  Width="150">
                                        <GridViewColumn.CellTemplate>
                                            <DataTemplate>
                                                <TextBlock Text="{Binding Avancement, StringFormat=\{0:C2\}}" Foreground="Green" TextAlignment="Right" />
                                            </DataTemplate>
                                        </GridViewColumn.CellTemplate>
                                    </GridViewColumn>

                                    <GridViewColumn Header="Objectif" Width="150">
                                        <GridViewColumn.CellTemplate>
                                            <DataTemplate>
                                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                                    <TextBlock Text="{Binding Objectif, StringFormat=\{0:C2\}}">
                                                        <TextBlock.Style>
                                                            <Style TargetType="{x:Type TextBlock}">
                                                                <Setter Property="Foreground" Value="Red"/>
                                                            </Style>
                                                        </TextBlock.Style>
                                                    </TextBlock>
                                                </StackPanel>
                                            </DataTemplate>
                                        </GridViewColumn.CellTemplate>
                                    </GridViewColumn>
                                    <GridViewColumn Header="Reste"  Width="150">
                                        <GridViewColumn.CellTemplate>
                                            <DataTemplate>
                                                <TextBlock Text="{Binding Reste, StringFormat=\{0:C2\}}" Foreground="Green" TextAlignment="Right" />
                                            </DataTemplate>
                                        </GridViewColumn.CellTemplate>
                                    </GridViewColumn>
                                    <GridViewColumn Header="Progression"  Width="150">
                                        <GridViewColumn.CellTemplate>
                                            <DataTemplate>
                                                <ProgressBar Value="{Binding Progression}" Maximum="100" Minimum="0" Width="150" Height="20"/>
                                            </DataTemplate>
                                        </GridViewColumn.CellTemplate>
                                    </GridViewColumn>
                                </GridView>
                            </ListView.View>
                        </ListView>
                    </StackPanel>
                    <StackPanel HorizontalAlignment="Center" Orientation="Horizontal" Margin="0,10">
                        <Button x:Name="btnCreerCategorie"  Content="Creer"  Width="100" Height="25" Click="btnCreerCategorie_Click"/>
                        <Button x:Name="btnModifierCategorie"  Content="Modifier"  Width="100" Height="25" Margin="10,0,0,0" Click="btnModifierCategorie_Click"/>
                        <Button x:Name="btnSupprimerCategorie"   Content="Supprimer"  Width="100" Height="25" Margin="10,0,0,0" Click="btnSupprimerCategorie_Click"/>
                    </StackPanel>
                </StackPanel>
            </GroupBox>
        </StackPanel>
    </Grid>
</Window>
