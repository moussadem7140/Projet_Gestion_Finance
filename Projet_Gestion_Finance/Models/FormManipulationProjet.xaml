<Window x:Class="Projet_Gestion_Finance.Models.FormManipulationProjet"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Projet_Gestion_Finance.Models"
        mc:Ignorable="d"
        Title="Gestions des Catégories" Height="410" Width="500" Loaded="Windows_Loaded" Background="#FF68B67C">
    <StackPanel Margin="10">
        <TextBlock Name="Titre" HorizontalAlignment="Left" Margin="10" FontWeight="Bold">Création d'une catégorie</TextBlock>
        <StackPanel Orientation="Horizontal" Margin="0,5" HorizontalAlignment="Left" >
            <Label  Width="75" FontWeight="Bold">Nom</Label>
            <TextBox x:Name="txtNom" Width="250"></TextBox>
        </StackPanel>
        <Label Foreground="Red" Name="txtNomErreur" Padding="0" FontSize="10" Height="15" Width="632" FontWeight="Bold"></Label>
        <StackPanel Orientation="Horizontal" Margin="0,5" HorizontalAlignment="Left">
            <Label  Width="75" FontWeight="Bold">Coût</Label>
            <TextBox x:Name="txtCout" Width="250" ></TextBox>
        </StackPanel>
        <Label Foreground="Red" Name="txtCoutErreur" Padding="0" FontSize="10" Height="15" Width="632" FontWeight="Bold"></Label>
        <StackPanel Orientation="Horizontal" Margin="0,5" HorizontalAlignment="Left">
            <Label Width="75"  FontWeight="Bold">Fréquence</Label>
            <ComboBox x:Name="cbxFrequence" Width="250"/>
        </StackPanel>
        <Label Foreground="Red" Name="cbxFrequenceErreur" Padding="0" FontSize="10" Height="15" Width="632" FontWeight="Bold"></Label>
        <StackPanel Orientation="Horizontal" Margin="0,5" HorizontalAlignment="Left">
            <Label  Width="75" FontWeight="Bold">Objectif</Label>
            <TextBox x:Name="txtObjectif" Width="250" ></TextBox>
        </StackPanel>
        <Label Foreground="Red" Name="txtObjectifErreur" Padding="0" FontSize="10" Height="15" Width="632" FontWeight="Bold"></Label>

        <StackPanel  Orientation="Horizontal" Margin="0,5" HorizontalAlignment="Left">
            <Label Width="75"  Content="Date"  FontWeight="Bold"/>
            <DatePicker Width="245" Name="dtpDate"/>
        </StackPanel>
        <Label Foreground="Red" Name="dtpDateErreur" Padding="0" FontSize="10" Height="15" Width="632" FontWeight="Bold"></Label>
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,10" Width="440" >
            <Button x:Name="btnCreer" Width="100"  Margin="5,10" Click="btnCreer_Click">Creer</Button>
            <Button x:Name="btnAnnuler" Width="100" Margin="5,10" Click="btnAnnuler_Click">Annuler</Button>
        </StackPanel>
    </StackPanel>
</Window>
