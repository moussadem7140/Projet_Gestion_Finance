<Window x:Class="Projet_Gestion_Finance.Models.FormDepense"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Projet_Gestion_Finance.Models"
        mc:Ignorable="d"
        Title="FormDepense" Height="450" Width="800" Loaded="Windows_Loaded">
    <StackPanel Margin="10"  >
        <StackPanel.Background>
            <ImageBrush ImageSource="/Ressource/fondImage.jpg" Stretch="UniformToFill"></ImageBrush>
        </StackPanel.Background>
        <TextBlock Name="Titre" HorizontalAlignment="Left" Margin="10" FontWeight="Bold" Foreground="White"></TextBlock>
        <StackPanel Orientation="Horizontal" Margin="0,5" HorizontalAlignment="Left">
            <Label Width="70" Foreground="White" FontWeight="Bold">Nom</Label>
            <TextBox x:Name="txtNom" Width="250"></TextBox>
        </StackPanel>
        <Label Foreground="Red" Name="txtNomErreur" Padding="0" FontSize="10" Height="15" Width="632" FontWeight="Bold"></Label>
        <StackPanel  Orientation="Horizontal" Margin="0,5" HorizontalAlignment="Left">
            <Label Width="70" Foreground="White" FontWeight="Bold">Coût</Label>
            <TextBox x:Name="txtCout" Width="250"></TextBox>
        </StackPanel>
        <Label Foreground="Red" Name="txtCoutErreur" Padding="0" FontSize="10" Height="15" Width="632" FontWeight="Bold"></Label>
        <StackPanel  Orientation="Horizontal" Margin="0,5" HorizontalAlignment="Left">
            <Label Width="70" Foreground="White" FontWeight="Bold">Catégorie</Label>
            <ComboBox x:Name="cbxCategorie" Width="250"/>
        </StackPanel>
        <Label Foreground="Red" Name="txtCategorieErreur" Padding="0" FontSize="10" Height="15" Width="632" FontWeight="Bold"></Label>
        <StackPanel Orientation="Horizontal" Margin="0,5" HorizontalAlignment="Left">
            <Label Width="70" Foreground="White" FontWeight="Bold">Fréquence</Label>
            <ComboBox x:Name="cbxFrequence" Width="250"/>
        </StackPanel>
        <Label Foreground="Red" Name="cbxFrequenceErreur" Padding="0" FontSize="10" Height="15" Width="632" FontWeight="Bold"></Label>
        <StackPanel  Orientation="Horizontal" Margin="0,5" HorizontalAlignment="Left">
            <Label Width="70"  Content="Date" Foreground="White" FontWeight="Bold"/>
            <DatePicker Width="245" Name="dtpDate"/>
        </StackPanel>
        <Label Foreground="Red" Name="dtpDateErreur" Padding="0" FontSize="10" Height="15" Width="632" FontWeight="Bold"></Label>
         <StackPanel  Orientation="Horizontal" Margin="70,5" HorizontalAlignment="Left">
            <CheckBox x:Name="chkOblig" Foreground="White" FontWeight="Bold">Obligatoire</CheckBox>
        </StackPanel>
        <Label Foreground="Red" Name="chkObligErreur" Padding="0" FontSize="10" Height="15" Width="632" FontWeight="Bold"></Label>
        <StackPanel  Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,10" Width="750">
            <Button x:Name="btnModifier" Width="100"  Margin="5,10" Click="btnModifier_Click">Modifier</Button>
            <Button x:Name="btnAnnuler" Width="100" Margin="5,10" Click="btnAnnuler_Click">Annuler</Button>
        </StackPanel>
    </StackPanel>
</Window>
